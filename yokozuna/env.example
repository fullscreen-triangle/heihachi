# Spotify OAuth (PKCE — no client secret needed)
# Get your Client ID from https://developer.spotify.com/dashboard
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Redirect URIs to register in Spotify Dashboard:
#   Production:  https://your-vercel-domain.vercel.app/api/spotify/callback
#   Local dev:   http://localhost:3000/api/spotify/callback
